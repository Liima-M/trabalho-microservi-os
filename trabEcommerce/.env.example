# ============================================================
# Arquivo de variáveis de ambiente
# Copie para .env e ajuste os valores antes de rodar em produção
# ============================================================

# JWT — use uma chave com ao menos 256 bits
JWT_SECRET=changeme-super-secret-key-at-least-256-bits-long!!

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Banco de dados (padrão já configurado no docker-compose.yml)
# DB_USER=postgres
# DB_PASS=postgres
